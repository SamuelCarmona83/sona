# Discord Bot Token
# Get from: https://discord.com/developers/applications → Bot → TOKEN
BOT_TOKEN=your_discord_bot_token_here

# Spotify OAuth Credentials
# Get from: https://developer.spotify.com/dashboard → Create App
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback
SPOTIFY_CACHE_PATH=.cache/spotify.cache
TASTE_CACHE_TTL_SEC=21600

# Discord Channels (integer IDs, not names)
# Right-click channel in Discord → Copy Channel ID
ALLOWED_CHANNEL_ID=1163479541029810226
VOICE_CHANNEL_ID=1397428777876721716

# YouTube / yt-dlp Configuration
# Path to cookies.txt file (export from browser via cookies.txt extension)
YTDL_COOKIES_FILE=/app/cookies.txt

# OPTIONAL: Extract cookies from browser instead of file
# Values: chrome, firefox, chrome:profile, firefox:profile
# In Docker on macOS, browser extraction inside the container is usually unreliable.
# Prefer refreshing ./cookies.txt from the host browser with ./refresh_cookies.sh
# YTDL_COOKIES_FROM_BROWSER=firefox

# Cookie selection mode: auto, file, browser
YTDL_COOKIES_PREFERENCE=auto
YTDL_COOKIE_MAX_AGE_HOURS=24
COOKIE_HEALTH_CHECK_INTERVAL_SEC=1800
COOKIE_ALERT_COOLDOWN_SEC=86400

# Request pacing to reduce YouTube bot checks / rate-limits
YTDL_SEARCH_CONCURRENCY=1
YTDL_SEARCH_DELAY_SEC=7.0
YTDL_SEARCH_JITTER_SEC=3.0

# Local music library (offline playback when YouTube blocks the bot)
LIBRARY_ENABLED=true
LIBRARY_PATH=.cache/library
LIBRARY_MAX_TRACKS=500
LIBRARY_MAX_MB=2048
LIBRARY_AUTO_DOWNLOAD=true
LIBRARY_MIN_PLAYS_TO_PIN=3
YOUTUBE_URL_CACHE_TTL_SEC=1800

# OPTIONAL: Override User-Agent to match your browser (must match cookie browser)
# Default: Chrome 120 (Mozilla/5.0 Windows NT 10.0; Win64; x64 AppleWebKit/537.36...)
# Use: Firefox User-Agent, Safari, Edge, etc.
# YTDL_USER_AGENT=your_browser_user_agent_here

# FFmpeg Audio Processing
# Enable/disable real-time loudness normalization (dynaudnorm)
# Values: 1, true, yes (enable) or 0, false, no (disable)
NORMALIZE_AUDIO=true

# LLM (Anthropic Claude) Configuration
# Optional: Leave empty to disable LLM tie-breaking
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# DJ Announcer (Text-to-Speech between songs)
# Enable/disable TTS announcements in radio mode
# Values: 1, true, yes (enable) or 0, false, no (disable)
DJ_ANNOUNCER_ENABLED=true

# Edge-TTS voice name (used for TTS announcements)
# List all: python -m edge_tts --list-voices
# Spanish: es-MX-DaliaNeural (Mexico), es-ES-AlvaroNeural (Spain)
# English: en-US-AriaNeural, en-GB-RyanNeural
DJ_VOICE=es-MX-DaliaNeural

# Cooldown between DJ announcements (seconds)
# 120 = announce after every ~2 mins of songs (if radio active)
DJ_ANNOUNCE_COOLDOWN=120

# Number of songs between DJ fun-fact comments
# 5 = announce a fun fact every 5 songs
DJ_FUN_FACT_INTERVAL=5

# DJ TTS provider: auto (ElevenLabs if key set, else edge) | elevenlabs | edge
DJ_TTS_PROVIDER=auto
# ElevenLabs (https://elevenlabs.io) — faster / higher quality Spanish voices
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_MODEL=eleven_multilingual_v2
# Duck DJ voice under local music (immersive radio). Requires local library file.
DJ_MIXER_ENABLED=false
DJ_MIXER_MUSIC_DUCK=0.55
# Mix short fun-facts under songs (false = sequential TTS for clips < DJ_MIXER_MIN_TTS_SEC)
DJ_MIXER_FUN_FACTS=false
DJ_MIXER_MIN_TTS_SEC=4
DJ_WELCOME_TIMEOUT_SEC=15

# FM live stream song recognition (shazamio — unofficial Shazam client)
# Samples the station stream in parallel and identifies the current song.
# Values: 1/true/yes or 0/false/no
FM_RECOGNIZER_ENABLED=true
# Seconds between recognition attempts (base interval)
FM_RECOGNIZER_INTERVAL_SEC=30
# Length of each audio sample sent to Shazam (3–15)
FM_RECOGNIZER_SAMPLE_SEC=8
# Announce track changes in the text channel
FM_RECOGNIZER_ANNOUNCE=true

# FM detection history (sessions for the data explorer web UI)
FM_HISTORY_ENABLED=true
FM_HISTORY_MAX_SESSIONS=200
FM_HISTORY_MAX_TRACKS_PER_SESSION=500

# Optional: override Rock & Pop stream URL for mood rock-radio
# FM_SEED_ROCK_STREAM_URL=https://playerservices.streamtheworld.com/api/livestream-redirect/ROCKANDPOPAAC.aac
# Tracks to queue immediately while waiting for first Shazam match
FM_SEED_COLD_FILL_COUNT=2
# When ads / no recognition leave the queue thin, refill rock tracks
FM_SEED_CONTINGENCY_FILL_COUNT=2
FM_SEED_CONTINGENCY_COOLDOWN_SEC=60

# Genius API (for lyrics, song annotations, high-quality/official song artwork)
# Get credentials: https://genius.com/api-clients (create client → use the Access Token)
# GENIUS_ACCESS_TOKEN is the main one used for api.genius.com (search + /songs/:id)
# CLIENT_ID/SECRET optional (for future OAuth flows)
GENIUS_ACCESS_TOKEN=
GENIUS_CLIENT_ID=
GENIUS_CLIENT_SECRET=

# FFmpeg volume multiplier for TTS (1.0 = normal)
# Increase if DJ voice is too quiet: 1.5, 2.0
# Decrease if too loud: 0.8
DJ_VOLUME=1.2
